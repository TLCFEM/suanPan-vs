{
  "allowScripts": {
    "@vscode/vsce-sign": true,
    "keytar": true
  },
  "author": {
    "email": "tlcfem@gmail.com",
    "name": "Theodore Chang"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "commands": [
      {
        "command": "suanpan.run",
        "title": "suanPan: Run this model in suanPan"
      }
    ],
    "configuration": {
      "properties": {
        "suanpan.color": {
          "default": true,
          "description": "Enable colorized output.",
          "ignoreSync": true,
          "type": "boolean"
        },
        "suanpan.cpus": {
          "default": 0,
          "description": "Number of logical cores to use in docker. 0 means using all available cores.",
          "ignoreSync": true,
          "type": "integer"
        },
        "suanpan.directory": {
          "default": "",
          "description": "Working directory, leave empty to use the folder of the model file.",
          "ignoreSync": true,
          "type": "string"
        },
        "suanpan.docker": {
          "default": false,
          "description": "Run the model in a docker container.",
          "ignoreSync": true,
          "type": "boolean"
        },
        "suanpan.image": {
          "default": "tlcfem/suanpan",
          "description": "Docker image to use.",
          "type": "string"
        },
        "suanpan.path": {
          "default": "",
          "description": "Path to the suanPan executable.",
          "ignoreSync": true,
          "type": "string"
        },
        "suanpan.verbose": {
          "default": false,
          "description": "Enable verbose output.",
          "ignoreSync": true,
          "type": "boolean"
        }
      },
      "title": "suanPan"
    },
    "grammars": [
      {
        "language": "suanPan",
        "path": "./syntaxes/syntax.json",
        "scopeName": "source.sp"
      }
    ],
    "languages": [
      {
        "aliases": [
          "suanPan"
        ],
        "configuration": "./syntaxes/language-configuration.json",
        "extensions": [
          ".sp",
          ".supan"
        ],
        "id": "suanPan"
      }
    ],
    "snippets": [
      {
        "language": "suanPan",
        "path": "./syntaxes/snippets.json"
      },
      {
        "language": "suanPan",
        "path": "./syntaxes/nz_sections.json"
      },
      {
        "language": "suanPan",
        "path": "./syntaxes/eu_sections.json"
      },
      {
        "language": "suanPan",
        "path": "./syntaxes/us_sections.json"
      }
    ]
  },
  "description": "Syntax highlighting and autocompletion for suanPan models",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.6.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3"
  },
  "displayName": "suanPan",
  "engines": {
    "vscode": "^1.125.0"
  },
  "icon": "images/suanPan-ua.png",
  "main": "./out/extension.js",
  "name": "suanpan",
  "overrides": {
    "css-what": "6.1.0"
  },
  "pricing": "Free",
  "publisher": "tlc",
  "repository": {
    "type": "git",
    "url": "https://github.com/TLCFEM/suanPan-vs"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc --watch -p ./"
  },
  "version": "0.1.14",
  "volta": {
    "node": "24.18.0"
  }
}